# Server
PORT=3000

# Claude AI (required for AI-powered triage)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# GitHub connector (optional)
GITHUB_TOKEN=ghp_your_github_token
GITHUB_ORG=your-org-name

# PagerDuty connector (optional)
PAGERDUTY_API_KEY=your_pagerduty_api_key
PAGERDUTY_SERVICE_ID=your_service_id

# AWS connector (optional)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1

# Generic HTTP connector (optional)
# Comma-separated list of webhook endpoints to watch
WEBHOOK_SOURCES=https://api.example.com/health,https://status.example.com
